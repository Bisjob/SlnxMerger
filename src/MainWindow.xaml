<Window x:Class="SlnxMerger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SlnxMerger"
        Title="{DynamicResource WindowTitle}"
        Icon="Resources/app.ico"
        Background="{StaticResource Brush.MainBackground}"
        Foreground="{StaticResource Brush.TextForeground}"
        Height="780" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextForeground}" />
            <Setter Property="Background" Value="{StaticResource Brush.PanelSurface}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.InteractiveAccent}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.InteractiveAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextForeground}" />
            <Setter Property="Background" Value="{StaticResource Brush.PanelSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.SubtleDivider}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3" />

                            <ContentPresenter Margin="8,2,26,2"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              RecognizesAccessKey="True" />

                            <ToggleButton Width="22"
                                          HorizontalAlignment="Right"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="{TemplateBinding Foreground}"
                                      Width="8"
                                      Height="4"
                                      Stretch="Fill"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Focusable="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border x:Name="PopupBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,2,0,0"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PopupBorder" Property="MinHeight" Value="24" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextForeground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.SubtleDivider}" />
            <Setter Property="Background" Value="{StaticResource Brush.PanelSurface}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="1"
                                    Margin="0,6,0,0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ContentPresenter Margin="{TemplateBinding Padding}" />
                            </Border>

                            <Border Grid.Row="0" Margin="12,0,12,0" Background="{TemplateBinding Background}" Padding="6,0">
                                <ContentPresenter ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextForeground}" />
            <Setter Property="Background" Value="{StaticResource Brush.PanelSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.SubtleDivider}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextForeground}" />
        </Style>

        <Style x:Key="ThemedToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextForeground}" />
            <Setter Property="Background" Value="{StaticResource Brush.PanelSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.SubtleDivider}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Track"
                                    Width="44"
                                    Height="22"
                                    CornerRadius="11"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Ellipse x:Name="Thumb"
                                         Width="18"
                                         Height="18"
                                         Fill="{StaticResource Brush.TextForeground}"
                                         HorizontalAlignment="Left"
                                         Margin="2,1,0,1" />
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.PanelSurface}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Brush.SubtleDivider}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="Thumb" Property="Margin" Value="2,1,0,1" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Brush.InteractiveAccent}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Brush.ActionHover}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,1,2,1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Brush.ActionHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextForeground}" />
            <Setter Property="Background" Value="{StaticResource Brush.InteractiveAccent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.SubtleDivider}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.ActionHover}" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.MainBackground}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Foreground" Value="{StaticResource Brush.TextForeground}" />
            <Setter Property="Background" Value="{StaticResource Brush.PanelSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.SubtleDivider}" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="{DynamicResource GroupLeftHeader}">
                <DockPanel Margin="4">
                    <Button DockPanel.Dock="Right" Content="{DynamicResource BrowseButton}" Padding="10,2"
                            Margin="6,0,0,0" Click="BrowseLeft_Click" />
                    <TextBox x:Name="LeftPathBox" VerticalContentAlignment="Center"
                             ToolTip="{DynamicResource LeftPathTooltip}" />
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="{DynamicResource GroupRightHeader}">
                <DockPanel Margin="4">
                    <Button DockPanel.Dock="Right" Content="{DynamicResource BrowseButton}" Padding="10,2"
                            Margin="6,0,0,0" Click="BrowseRight_Click" />
                    <TextBox x:Name="RightPathBox" VerticalContentAlignment="Center"
                             ToolTip="{DynamicResource RightPathTooltip}" />
                </DockPanel>
            </GroupBox>
        </Grid>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="{DynamicResource CompareButton}" FontWeight="Bold" Padding="14,5"
                    Click="Compare_Click" />
            <ToggleButton x:Name="OnlyCommonRootsBox" Content="{DynamicResource OnlyCommonRoots}"
                          Style="{StaticResource ThemedToggleSwitchStyle}"
                          IsChecked="True" Margin="16,0,0,0" VerticalAlignment="Center"
                          ToolTip="{DynamicResource OnlyCommonRootsTooltip}"
                          Checked="Option_Changed" Unchecked="Option_Changed" />
            <ToggleButton x:Name="OnlyDiffBox" Content="{DynamicResource OnlyDiff}"
                          Style="{StaticResource ThemedToggleSwitchStyle}"
                          IsChecked="True" Margin="16,0,0,0" VerticalAlignment="Center"
                          Checked="Option_Changed" Unchecked="Option_Changed" />
            <Button Content="{DynamicResource CheckAll}" Padding="10,3" Margin="24,0,0,0" Click="CheckAll_Click" />
            <Button Content="{DynamicResource UncheckAll}" Padding="10,3" Margin="6,0,0,0" Click="UncheckAll_Click" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="2,0,0,6">
            <TextBlock Text="●" Foreground="{StaticResource Brush.Success}" FontWeight="Bold" />
            <TextBlock Text="{DynamicResource LegendOnlyLeft}" Margin="3,0,10,0" />
            <TextBlock Text="●" Foreground="{StaticResource Brush.Danger}" FontWeight="Bold" />
            <TextBlock Text="{DynamicResource LegendOnlyRight}" Margin="3,0,10,0" />
            <TextBlock Text="●" Foreground="{StaticResource Brush.TextForeground}" FontWeight="Bold" />
            <TextBlock Text="{DynamicResource LegendSame}" Margin="3,0,0,0"  />
        </StackPanel>

        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" HorizontalAlignment="Left" Padding="14,6"
                    Click="ApplyToLeft_Click"
                    ToolTip="{DynamicResource ApplyToLeftTooltip}">
                <TextBlock Text="{DynamicResource ApplyToLeftButton}" FontWeight="SemiBold" />
            </Button>

            <TextBlock Grid.Column="1" x:Name="SummaryText" VerticalAlignment="Center"
                       Foreground="{StaticResource Brush.TextForeground}" Margin="12,0" Opacity="0.85" />

            <Button Grid.Column="2" HorizontalAlignment="Right" Padding="14,6"
                    Click="ApplyToRight_Click"
                    ToolTip="{DynamicResource ApplyToRightTooltip}">
                <TextBlock Text="{DynamicResource ApplyToRightButton}" FontWeight="SemiBold" />
            </Button>
        </Grid>

        <Border DockPanel.Dock="Bottom" Background="{StaticResource Brush.PanelSurface}" BorderBrush="{StaticResource Brush.SubtleDivider}" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="StatusText" Text="{DynamicResource InitialStatus}"
                           TextWrapping="Wrap" VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{DynamicResource LanguageLabel}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="LanguageSelector"
                              Width="120"
                              Style="{StaticResource DarkComboBoxStyle}"
                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                              SelectionChanged="LanguageSelector_SelectionChanged">
                        <ComboBoxItem Tag="fr-FR" Content="{DynamicResource LanguageFrench}" />
                        <ComboBoxItem Tag="en-US" Content="{DynamicResource LanguageEnglish}" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <TreeView x:Name="DiffTree" BorderBrush="{StaticResource Brush.SubtleDivider}" BorderThickness="1">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                </Style>
            </TreeView.ItemContainerStyle>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type local:DiffNodeViewModel}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="0,1">
                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                  VerticalAlignment="Center" Margin="0,0,5,0"
                                  Visibility="{Binding IsActionable, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding Icon}" Margin="0,0,5,0"
                                   FontFamily="Segoe MDL2 Assets"
                                   Foreground="{Binding StatusColor}" />
                        <TextBlock Text="{Binding Name}" Foreground="{Binding StatusColor}"
                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusLabel}" Foreground="{Binding StatusColor}"
                                   FontStyle="Italic" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

    </DockPanel>
</Window>
